# 部署域名（生产环境必填）
DOMAIN=xhs-auto.tools.sn0wpear.com

LLM_API_KEY=sk-your-api-key-here
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-v4-pro
LLM_TEMPERATURE=0.7

# 开发环境数据库（SQLite）
DATABASE_URL=sqlite:///./xhs.db

# 生产环境数据库（PostgreSQL）
# DATABASE_URL=postgresql://xhs:xhs_secure_pwd@postgres:5432/xhs_app

# 生产环境 Redis
# REDIS_URL=redis://redis:6379/0

# 每日免费使用次数
FREE_DAILY_LIMIT=3
