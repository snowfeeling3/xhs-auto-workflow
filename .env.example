# 部署域名（生产环境必填）
DOMAIN=your-domain.com

LLM_API_KEY=sk-your-api-key-here
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-v4-pro
LLM_TEMPERATURE=0.7

# 开发环境数据库（SQLite）
DATABASE_URL=sqlite:///./xhs.db

# 生产环境数据库（PostgreSQL）
# DATABASE_URL=postgresql://xhs:xhs_secure_pwd@postgres:5432/xhs_app

# 生产环境 Redis
# REDIS_URL=redis://redis:6379/0

# 积分与付款
NEW_USER_CREDITS=1              # 新用户初始免费积分（设置为0则不赠送）
PAYMENT_QR_URL=/static/qr_payment.png  # 收款二维码路径（URL或本地静态文件路径）
PAYMENT_AUTO_VERIFY=false       # 是否自动验证付款（true=付款后自动到账）
ADMIN_KEY=admin123              # 管理后台密钥（修改为强密码）
